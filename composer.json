{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4",
        "fideloper/proxy": "^4.2",
        "fruitcake/laravel-cors": "^1.0",
        "fzaninotto/faker": "^1.9.1",
        "grosv/eloquent-sheets": "dev-master",
        "grosv/laravel-cloudinary": "dev-master",
        "grosv/laravel-passwordless-login": "dev-master",
        "guzzlehttp/guzzle": "^6.3",
        "laravel/framework": "^7.0",
        "laravel/tinker": "^2.0",
        "laravel/ui": "^2.0",
        "laravel/vapor-cli": "^1.6",
        "laravel/vapor-core": "^2.7",
        "league/flysystem-aws-s3-v3": "^1.0",
        "livewire/livewire": "^1.0",
        "spatie/yaml-front-matter": "^2.0"
    },
    "require-dev": {
        "facade/ignition": "^2.0",
        "grosv/laravel-git-workflow": "dev-master",
        "grosv/stubby": "dev-master",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^4.1",
        "nunomaduro/laravel-mojito": "^0.2.4",
        "phpunit/phpunit": "^8.5",
        "timacdonald/log-fake": "^1.6",
        "ext-mysqli": "*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": {
        "0": {
            "type": "path",
            "url": "../../../Packages/grosv/stubby"
        },
        "4": {
            "url": "https://github.com/grosv/cloudinary",
            "type": "git"
        },
        "5": {
            "url": "../../../Packages/grosv/laravel-cloudinary",
            "type": "path"
        },
        "6": {
            "url": "../../../Packages/grosv/laravel-git-workflow",
            "type": "path"
        },
        "7": {
            "url": "../../../Packages/grosv/eloquent-sheets",
            "type": "path"
        },
        "8": {
            "url": "../../../Packages/grosv/laravel-passwordless-login",
            "type": "path"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}